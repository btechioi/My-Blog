{
  "name": "btech-ioi-blog",
  "type": "module",
  "version": "3.0.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "generate:lqips": "npx tsx src/scripts/generateLqips.ts",
    "generate:similarities": "npx tsx src/scripts/generateSimilarities.ts",
    "generate:summaries": "npx tsx src/scripts/generateSummaries.ts",
    "generate:summaries:force": "npx tsx src/scripts/generateSummaries.ts --force",
    "generate:all": "npm run generate:lqips && npm run generate:summaries && npm run generate:similarities",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:fix:unssafe": "biome check --write --unsafe",
    "format": "biome format --write .",
    "lint-md": "lint-md ./src/content/**/*.{md,mdx}",
    "lint-md:fix": "lint-md ./src/content/**/*.{md,mdx} --fix",
    "lint-staged": "lint-staged",
    "change": "git cliff --bump -o CHANGELOG.md",
    "prepare": "husky",
    "knip": "knip",
    "koharu": "npx tsx scripts/koharu.tsx"
  },

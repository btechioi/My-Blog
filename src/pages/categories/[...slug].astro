---
import CategoryPostList from '@components/category/CategoryPostList.astro';
import HomeSider from '@components/layout/HomeSider.astro';
import Cover from '@components/ui/cover/Cover.astro';
import { seoConfig, siteConfig } from '@constants/site-config';
import Layout from '@layouts/Layout.astro';
import TwoColumnLayout from '@layouts/TwoColumnLayout.astro';
import { buildCategoryPath, getCategoryByLink, getCategoryLinks, getCategoryList, translateCategoryName } from '@lib/content';
import { defaultLocale, getLocaleFromUrl, localizedPath, t } from '@/i18n';

export async function getStaticPaths() {
  const { categories } = await getCategoryList(defaultLocale);
  const links = getCategoryLinks(categories, '');
  return links.map((link) => {
    const category = getCategoryByLink(categories, link);
    return {
      params: { slug: link },
      props: { category },
    };
  });
}

const { category: propCategory } = Astro.props;
const locale = getLocaleFromUrl(Astro.url.pathname);
const { categories: allCategories, countMap } = await getCategoryList(locale);

// Re-derive category from locale-aware data to ensure consistency with countMap.
const slug = Astro.params.slug;
const category = slug ? getCategoryByLink(allCategories, slug) : propCategory;

// If the category is featured, use its configured cover image
const featuredCategory = siteConfig.featuredCategories?.find((item) => item.link === slug);
const coverImage = featuredCategory?.image;

const displayCategories = category ? [category] : allCategories;
const categoryName = translateCategoryName(category?.name ?? '', locale);
const homeName = t(locale, 'breadcrumb.home');

// Breadcrumb structured data
const breadcrumbListItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: homeName,
    item: new URL(localizedPath('/', locale), Astro.site).href,
  },
  {
    '@type': 'ListItem',
    position: 2,
    name: t(locale, 'nav.categories'),
    item: new URL(localizedPath('/categories', locale), Astro.site).href,
  },
  ...(category && slug
    ? [
        {
          '@type': 'ListItem' as const,
          position: 3,
          name: categoryName,
          item: new URL(localizedPath(buildCategoryPath([slug]), locale), Astro.site).href,
        },
      ]
    : []),
];

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbListItems,
};
---

<Layout title={`${t(locale, 'category.postsInCategory', { name: categoryName })} | ${seoConfig.title}`}>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <TwoColumnLayout>
    <Cover
      slot="cover"
      title={t(locale, 'category.postsInCategory', { name: categoryName })}
      cover={coverImage}
    />
    <HomeSider slot="sider" />
    <CategoryPostList rootCategory={category} categories={displayCategories} countMap={countMap} />
  </TwoColumnLayout>
</Layout>
